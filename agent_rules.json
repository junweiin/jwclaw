{
  "security": {
    "forbidden_commands": [
      "rm -rf /",
      "format C:",
      "del /s /q C:\\*",
      "shutdown -s -t 0"
    ],
    "forbidden_operations": [
      "delete_system_files",
      "modify_registry_critical",
      "disable_security_software"
    ],
    "require_confirmation": [
      "delete_multiple_files",
      "modify_system_settings",
      "install_software"
    ],
    "max_file_operations": 100,
    "protected_directories": [
      "C:\\Windows",
      "C:\\Program Files",
      "C:\\ProgramData"
    ]
  },
  "behavior": {
    "language": "zh-CN",
    "response_style": "concise",
    "always_think_before_act": true,
    "prefer_local_skills": true,
    "never_say_cannot": true,
    "auto_save_experience": true
  },
  "execution": {
    "max_retries": 3,
    "timeout_seconds": 300,
    "parallel_tasks": false,
    "cache_successful_results": true,
    "log_all_operations": true
  },
  "learning": {
    "save_success_patterns": true,
    "record_failure_reasons": true,
    "memory_decay_days": 90,
    "min_usage_count_to_keep": 2,
    "auto_cleanup_memory": true
  },
  "privacy": {
    "never_store_passwords": true,
    "never_store_api_keys_plain": true,
    "encrypt_sensitive_data": true,
    "ask_before_sharing": true
  }
}